{
  "name": "@aimaid/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "AIMaid Electron desktop shell",
  "author": "AIMaid",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "postinstall": "install-electron --no",
    "predev": "npm run core:build",
    "dev": "electron-vite dev",
    "core:build": "dotnet build ../../src/AIMaid.CoreHost/AIMaid.CoreHost.csproj -c Debug",
    "core:publish": "node scripts/publish-core.mjs",
    "ui:gate": "node scripts/check-ui-boundary.mjs",
    "typecheck": "npm run ui:gate && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint . --max-warnings=0",
    "pretest": "npm run core:build",
    "test": "vitest run",
    "build": "npm run typecheck && npm run core:publish && electron-vite build",
    "pack": "node scripts/clean-local-package.mjs && npm run build && electron-builder --dir",
    "pack:local": "node scripts/kill-packaged-app.mjs && npm run build && node scripts/merge-local-package.mjs"
  },
  "dependencies": {
    "@pixi/sound": "^5.2.3",
    "@pixi/unsafe-eval": "^7.4.3",
    "pixi-live2d-display-lipsyncpatch": "^0.5.0-ls-8",
    "pixi.js": "^7.4.3",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "24.10.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "eslint": "9.39.2",
    "globals": "17.3.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vite": "7.3.6",
    "vitest": "4.1.0"
  },
  "build": {
    "appId": "com.aimaid.desktop",
    "productName": "AIMaid",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/core",
        "to": "core",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/live2d",
        "to": "live2d",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/ui",
        "to": "ui",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "win": {
      "icon": "resources/ui/maid_assistant_icon.ico",
      "target": "dir"
    }
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  }
}
